arr=list(map(int,input().split())
key=int(input())
low=0
high=len(arr)-1
found=False
while low<=high:
         mid=(low+high)//2
         if arr[mid]==key:
              found=True
               break
         elif arr[mid]<key:
              low=mid+1
         else:
             low=mid-1
if found:
         print("found")
else:
         print("not found")
